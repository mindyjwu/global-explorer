# Map tile configuration
# Phase 1 uses OpenFreeMap (no key required — leave blank)
# To use Maptiler or Stadia instead, add your key here and update src/lib/constants.ts MAP_STYLE
VITE_MAP_TILES_KEY=

# GeoNames city data fetching (Phase 2+)
# Register free at https://www.geonames.org/login — never commit your actual username
# Copy this file to .env.local and fill in your values
GEONAMES_USER=
